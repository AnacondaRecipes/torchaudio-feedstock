From 5091225a034f4a35c31e19b6aa9e204263904a26 Mon Sep 17 00:00:00 2001
From: Jamie Robertson <jamierobertsongames@gmail.com>
Date: Sun, 22 Feb 2026 10:56:49 +0000
Subject: [PATCH] Fix FFmpeg 8.0 rename of 'channels' demuxer option to
 'ch_layout'

FFmpeg 8.0 removed the 'channels' option from raw audio demuxers
(f32le, mulaw, s16le, etc.) as part of the channel layout API
overhaul. The option was renamed to 'ch_layout', and the value
format changed from an integer string (e.g. "3") to a channel
layout string (e.g. "3c" meaning "3 unspecified channels").

Update both occurrences in AudioEffector._get_reader() where the
demuxer option dict is built for headerless raw audio formats.

Co-authored-by: Cursor <cursoragent@cursor.com>
---
 src/torchaudio/io/_effector.py | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/torchaudio/io/_effector.py b/src/torchaudio/io/_effector.py
index 74255684..5c174725 100644
--- a/src/torchaudio/io/_effector.py
+++ b/src/torchaudio/io/_effector.py
@@ -264,12 +264,12 @@ class AudioEffector:
             option = {}
             # Some formats are headerless, so need to provide these infomation.
             if self.format == "mulaw":
-                option = {"sample_rate": f"{sample_rate}", "channels": f"{num_channels}"}
+                option = {"sample_rate": f"{sample_rate}", "ch_layout": f"{num_channels}c"}
 
         else:  # PCM
             muxer = _get_muxer(waveform.dtype)
             encoder = None
-            option = {"sample_rate": f"{sample_rate}", "channels": f"{num_channels}"}
+            option = {"sample_rate": f"{sample_rate}", "ch_layout": f"{num_channels}c"}
 
         if frames_per_chunk is None:
             src = _encode(waveform, sample_rate, self.effect, muxer, encoder, self.codec_config)
